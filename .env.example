# --- Auth ---
AUTH_USERNAME=your_username
AUTH_PASSWORD_HASH=<bcrypt hash — generate with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))">
JWT_SECRET=<64-char hex string — generate with: python -c "import secrets; print(secrets.token_hex(32))">
JWT_EXPIRE_HOURS=24

# --- Encryption (for Plaid access tokens at rest) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<fernet key>

# --- Plaid ---
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox   # sandbox | development | production

# --- AI (Sage) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...   # For Sage's lifelike voice (OpenAI TTS "onyx"). Optional — falls back to browser TTS if not set.

# --- Coinbase (Advanced Trade API — CDP keys) ---
# Create at: coinbase.com → Developer Platform → API Keys → Create new key (read-only portfolio scope)
# Key name format: organizations/<org-id>/apiKeys/<key-id>
COINBASE_API_KEY_NAME=organizations/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/apiKeys/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Paste the EC private key exactly as shown — the \n characters are intentional
COINBASE_API_KEY_PRIVATE=-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY-----\n

# --- Web Search (Tavily) ---
# Gives Sage full internet access: stock prices, tax rules, rates, news, etc.
# Free tier: 1,000 searches/month. Sign up at app.tavily.com
TAVILY_API_KEY=tvly-...
