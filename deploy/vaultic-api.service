# systemd service for the Vaultic FastAPI backend
#
# One-time setup on server:
#   sudo cp deploy/vaultic-api.service /etc/systemd/system/vaultic-api.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable vaultic-api
#   sudo systemctl start vaultic-api

[Unit]
Description=Vaultic FastAPI Backend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/vaultic
ExecStart=/home/ubuntu/vaultic/.venv/bin/uvicorn api.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5
# .env is loaded by load_dotenv() in api/main.py, but EnvironmentFile makes
# the vars available to the process environment as a safety net
# NOTE: Do NOT use EnvironmentFile here. systemd's parser mangles multi-line
# PEM keys (like the Coinbase EC private key stored with \n sequences).
# load_dotenv() in api/main.py handles .env loading correctly instead.

[Install]
WantedBy=multi-user.target
