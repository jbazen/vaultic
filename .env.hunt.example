# ─────────────────────────────────────────────────────────────────────────────
# hunt_a1.py configuration — copy this to .env.hunt and fill in your values
# .env.hunt is gitignored (same as .env)
# ─────────────────────────────────────────────────────────────────────────────

# ── OCI Identity ─────────────────────────────────────────────────────────────
# Console → Profile (top-right) → User Settings → copy "OCID" at top of page
OCI_USER_OCID=ocid1.user.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Console → Profile → Tenancy → copy "OCID" at top of page
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Console → Profile → User Settings → API Keys → Add API Key
# After adding: fingerprint shown as xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx

# Full path to the private key file you downloaded when adding the API key
OCI_KEY_FILE=/home/ubuntu/.oci/oci_api_key.pem

# ── Target Region ─────────────────────────────────────────────────────────────
# us-phoenix-1 | us-ashburn-1 | us-chicago-1 | eu-frankfurt-1 | etc.
OCI_REGION=us-phoenix-1

# ── Compartment ───────────────────────────────────────────────────────────────
# Use your tenancy OCID here to place the instance in the root compartment
# (same as OCI_TENANCY_OCID unless you created a sub-compartment)
OCI_COMPARTMENT_OCID=ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Network ───────────────────────────────────────────────────────────────────
# Console → Networking → Virtual Cloud Networks → Create VCN
# Use "Create VCN with Internet Connectivity" wizard — it creates subnet automatically
# Then: click your VCN → Subnets → click the public subnet → copy OCID
OCI_SUBNET_OCID=ocid1.subnet.oc1.phx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SSH Key ───────────────────────────────────────────────────────────────────
# Your public key — the FULL string including "ssh-rsa" prefix
# Get it: cat ~/.ssh/id_rsa.pub  (or id_ed25519.pub)
OCI_SSH_PUBLIC_KEY=ssh-rsa AAAAB3NzaC1yc2EAAAA...

# ── Image ─────────────────────────────────────────────────────────────────────
# Ubuntu 22.04 aarch64 (ARM) image OCID for your region
# Find it: python hunt_a1.py --list-images
# Or Console → Compute → Images → Platform Images → filter "Canonical Ubuntu" + "aarch64"
OCI_IMAGE_OCID=ocid1.image.oc1.phx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── A1.Flex Sizing ────────────────────────────────────────────────────────────
# Recommended: 1 large instance (4 OCPU / 24GB) — runs all your apps forever free
# Alternatives: 2 OCPU / 12GB (medium) or 1 OCPU / 6GB (small, up to 4 allowed)
OCI_A1_OCPUS=4
OCI_A1_MEMORY=24
OCI_BOOT_VOL_GB=50
OCI_INSTANCE_NAME=vaultic-a1

# ── Polling ───────────────────────────────────────────────────────────────────
# How often to check (minutes). 5 is polite. Don't go below 2.
POLL_MINUTES=5

# ── Email Notification (optional) ─────────────────────────────────────────────
# Get an email the moment your instance is created (even if you're asleep)
# Gmail: use an App Password (not your regular password)
#   Enable at: myaccount.google.com/apppasswords
NOTIFY_EMAIL=jason.bazen@yahoo.com
SMTP_FROM=your.gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
